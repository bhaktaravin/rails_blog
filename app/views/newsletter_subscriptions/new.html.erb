<div class="max-w-md mx-auto mt-10 p-6 bg-white rounded-lg shadow-md">
  <h1 class="text-2xl font-bold mb-4">Subscribe to Newsletter</h1>
  
  <p class="text-gray-600 mb-6">
    Get weekly updates on the latest blog posts delivered to your inbox.
  </p>

  <%= form_with model: @newsletter_subscription, url: newsletter_subscriptions_path, local: true, class: "space-y-4" do |form| %>
    <% if @newsletter_subscription.errors.any? %>
      <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded">
        <ul class="list-disc list-inside">
          <% @newsletter_subscription.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.email_field :email, 
          placeholder: "your@email.com",
          class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <%= form.submit "Subscribe", 
          class: "w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 transition cursor-pointer" %>
    </div>
  <% end %>

  <p class="text-xs text-gray-500 mt-4">
    You can unsubscribe at any time using the link in the newsletter.
  </p>
</div>
